# === Telegram ===
BOT_TOKEN=your-telegram-bot-token-here

# === PostgreSQL ===
POSTGRES_USER=fifa26
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fifa26
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Полный async DSN (используется приложением); собирается из переменных выше
DATABASE_URL=postgresql+asyncpg://fifa26:change-me@localhost:5432/fifa26

# === App ===
LOG_LEVEL=INFO
# Telegram-ID админов через запятую (доступ к /stats и /results). Пусто = ни у кого.
ADMIN_IDS=

# === Реальные результаты (точность прогнозов) ===
# football-data.org — надёжный источник результатов (free tier, есть ЧМ).
# Токен: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
# (устарело, не используется) веб-поиск Groq/Tavily оказался ненадёжным.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
TAVILY_API_KEY=
# Часы (0–23) в зоне SCHEDULE_TZ: срез результатов из API и рассылка сводок игрокам
RESULTS_FETCH_HOUR=6
DIGEST_HOUR=14
SCHEDULE_TZ=Europe/Berlin
# Мастер-переключатель авто-режима (ночная авто-запись из веба + утренняя рассылка).
# Держать false, пока нет надёжного источника результатов (веб-поиск ненадёжен).
RESULTS_AUTO=false
