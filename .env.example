# === Telegram ===
BOT_TOKEN=your-telegram-bot-token-here

# === PostgreSQL ===
POSTGRES_USER=fifa26
# Обязателен: docker-compose.yml не поднимется без заданного пароля.
POSTGRES_PASSWORD=
POSTGRES_DB=fifa26
POSTGRES_PORT=5432

# Полный async DSN (используется приложением). Хост зависит от режима запуска:
#  - dev (docker-compose.yml, бот в контейнере рядом с БД): хост `db` (имя сервиса)
#  - prod (docker-compose.prod.yml, network_mode: host + внешний Postgres): хост `localhost`
#  - запуск бота локально без Docker, БД в dev-compose: хост `localhost`
DATABASE_URL=postgresql+asyncpg://fifa26:<password>@db:5432/fifa26
# DATABASE_URL=postgresql+asyncpg://fifa26:<password>@localhost:5432/fifa26

# === App ===
LOG_LEVEL=INFO
# Telegram-ID админов через запятую (доступ к скрытой команде /stats). Пусто = ни у кого.
ADMIN_IDS=
